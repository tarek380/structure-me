    <script>
      // Menu overlay
      (function () {
        var toggle = document.getElementById('navToggle');
        var overlay = document.getElementById('navOverlay');
        if (!toggle || !overlay) return;
        var links = overlay.querySelectorAll('[data-overlay-link]');
        var open = function () {
          overlay.classList.add('is-open');
          overlay.setAttribute('aria-hidden', 'false');
          toggle.classList.add('is-active');
          toggle.setAttribute('aria-expanded', 'true');
          document.body.classList.add('nav-open');
        };
        var close = function () {
          overlay.classList.remove('is-open');
          overlay.setAttribute('aria-hidden', 'true');
          toggle.classList.remove('is-active');
          toggle.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('nav-open');
        };
        toggle.addEventListener('click', function () {
          if (overlay.classList.contains('is-open')) close(); else open();
        });
        for (var i = 0; i < links.length; i++) {
          links[i].addEventListener('click', function () { setTimeout(close, 60); });
        }
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('is-open')) close();
        });
      })();

      // Insights filter + dynamic hero
      (function () {
        var filters = document.querySelectorAll('.insights-filter');
        var gridCards = document.querySelectorAll('.insights-grid [data-card]');
        var empty = document.getElementById('insightsEmpty');
        var count = document.getElementById('insightsCount');
        var featured = document.getElementById('featuredCard');

        // Snapshot the original featured-card content so we can restore it on "All".
        var originalFeatured = featured ? {
          href: featured.getAttribute('href'),
          category: featured.getAttribute('data-category'),
          date: featured.getAttribute('data-date'),
          image: featured.getAttribute('data-image'),
          flag: featured.querySelector('.insights-featured-flag').innerHTML,
          title: featured.querySelector('.insights-featured-title').innerHTML,
          dek: featured.querySelector('.insights-featured-dek').innerHTML,
          metaHTML: featured.querySelector('.insights-featured-meta').innerHTML
        } : null;

        var labels = {
          advisory: 'Advisory',
          structuring: 'Structuring',
          international: 'International',
          'family-office': 'Family Office',
          exit: 'Exit'
        };

        function fmtDate(iso) {
          var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
          var parts = iso.split('-');
          if (parts.length !== 3) return iso;
          var d = parseInt(parts[2], 10);
          var m = months[parseInt(parts[1], 10) - 1] || '';
          return d + ' ' + m + ' ' + parts[0];
        }

        function pickLatest(filter) {
          var pool = [];
          gridCards.forEach(function (c) {
            if (filter === 'all' || c.getAttribute('data-category') === filter) pool.push(c);
          });
          pool.sort(function (a, b) {
            return (b.getAttribute('data-date') || '').localeCompare(a.getAttribute('data-date') || '');
          });
          return pool[0] || null;
        }

        function setFeaturedFromCard(card, filter) {
          if (!featured || !card) return;
          var cat = card.getAttribute('data-category');
          var date = card.getAttribute('data-date') || '';
          var img = card.getAttribute('data-image') || '';
          var titleEl = card.querySelector('.insights-card-title');
          var dekEl = card.querySelector('.insights-card-dek');
          var metaEl = card.querySelector('.insights-card-meta');
          var meta = metaEl ? metaEl.textContent : '';
          // Extract minutes (e.g. "6 min") from the meta text.
          var minMatch = meta.match(/(\d+\s*min)/i);
          var minRead = minMatch ? minMatch[1] : '';
          var flagLabel = filter === 'all' ? (labels[cat] || 'Featured') : (labels[filter] || 'Featured');

          featured.setAttribute('href', card.getAttribute('href') || '#');
          featured.setAttribute('data-category', cat || '');
          featured.setAttribute('data-date', date);
          featured.setAttribute('data-image', img);
          featured.querySelector('.insights-featured-flag').textContent = '— ' + (filter === 'all' ? 'Featured' : 'Latest') + ' · ' + flagLabel;
          featured.querySelector('.insights-featured-title').innerHTML = titleEl ? titleEl.innerHTML : '';
          featured.querySelector('.insights-featured-dek').innerHTML = dekEl ? dekEl.innerHTML : '';
          featured.querySelector('.insights-featured-meta').innerHTML =
            '<span>' + fmtDate(date) + '</span>' +
            '<span class="insights-featured-meta-sep" aria-hidden="true"></span>' +
            (minRead ? '<span>' + minRead + ' read</span><span class="insights-featured-meta-sep" aria-hidden="true"></span>' : '') +
            '<span>Read piece →</span>';
          var imgEl = featured.querySelector('.insights-featured-image');
          if (imgEl && img) imgEl.style.backgroundImage = "url('" + img + "')";
        }

        function restoreFeatured() {
          if (!featured || !originalFeatured) return;
          featured.setAttribute('href', originalFeatured.href);
          featured.setAttribute('data-category', originalFeatured.category);
          featured.setAttribute('data-date', originalFeatured.date);
          featured.setAttribute('data-image', originalFeatured.image);
          featured.querySelector('.insights-featured-flag').innerHTML = originalFeatured.flag;
          featured.querySelector('.insights-featured-title').innerHTML = originalFeatured.title;
          featured.querySelector('.insights-featured-dek').innerHTML = originalFeatured.dek;
          featured.querySelector('.insights-featured-meta').innerHTML = originalFeatured.metaHTML;
          var imgEl = featured.querySelector('.insights-featured-image');
          if (imgEl) imgEl.style.backgroundImage = "url('" + originalFeatured.image + "')";
        }

        function apply(filter) {
          var visible = 0;
          gridCards.forEach(function (card) {
            var cat = card.getAttribute('data-category');
            var match = filter === 'all' || cat === filter;
            if (match) {
              card.classList.remove('is-hidden');
              visible++;
            } else {
              card.classList.add('is-hidden');
            }
          });
          if (empty) empty.classList.toggle('is-visible', visible === 0);
          if (count) count.textContent = visible + (visible === 1 ? ' piece' : ' pieces');

          // Swap the hero: restore default on "all", else latest article in category.
          if (filter === 'all') {
            restoreFeatured();
          } else {
            var latest = pickLatest(filter);
            if (latest) setFeaturedFromCard(latest, filter);
            else restoreFeatured();
          }
        }

        filters.forEach(function (btn) {
          btn.addEventListener('click', function () {
            filters.forEach(function (b) {
              b.classList.remove('is-active');
              b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-selected', 'true');
            apply(btn.getAttribute('data-filter'));
          });
        });
      })();
    </script>
    <aside class="sub-widget" id="subWidget" role="complementary" aria-label="Subscribe to Structure Me Insights" aria-hidden="true">
      <button type="button" class="sub-widget-close" id="subWidgetClose" aria-label="Dismiss subscribe panel">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M5 5 L19 19 M19 5 L5 19"/></svg>
      </button>
      <div class="sub-widget-inner">
        <div class="sub-widget-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6 L21 6 L21 19 L3 19 Z"/><path d="M3 6 L12 14 L21 6"/></svg>
        </div>
        <span class="sub-widget-eyebrow">— Structure Me Insights</span>
        <h3 class="sub-widget-title">Read the next <em>essay</em> in your inbox.</h3>
        <p class="sub-widget-copy">Slow, considered pieces on entities, jurisdictions and succession — roughly monthly.</p>
        <form class="sub-widget-form" id="subWidgetForm" novalidate>
          <input type="text" name="name" class="sub-widget-input" placeholder="Name" autocomplete="name" required>
          <input type="email" name="email" class="sub-widget-input" placeholder="Email" autocomplete="email" required>
          <button type="submit" class="sub-widget-submit">
            <span>Subscribe</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
          <p class="sub-widget-consent">No spam. One-click unsubscribe.</p>
        </form>
      </div>
    </aside>

    <script>
      (function () {
        var w = document.getElementById('subWidget');
        var closeBtn = document.getElementById('subWidgetClose');
        var form = document.getElementById('subWidgetForm');
        if (!w || !form) return;

        var STORAGE_KEY = 'sm_subscribe_dismissed';
        if (sessionStorage.getItem(STORAGE_KEY) === '1') return;

        var shown = false;
        function show() {
          if (shown) return;
          shown = true;
          w.classList.add('is-open');
          w.setAttribute('aria-hidden', 'false');
        }
        function dismiss() {
          w.classList.remove('is-open');
          w.classList.add('is-hidden');
          w.setAttribute('aria-hidden', 'true');
          try { sessionStorage.setItem(STORAGE_KEY, '1'); } catch (e) {}
        }
        // Show shortly after page load on every visit (unless dismissed this session)
        setTimeout(show, 800);

        closeBtn.addEventListener('click', dismiss);

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          if (!form.checkValidity()) { form.reportValidity(); return; }
          var fd = new FormData(form);
          var name = (fd.get('name') || '').toString().trim();
          var email = (fd.get('email') || '').toString().trim();
          try { sessionStorage.setItem(STORAGE_KEY, '1'); } catch (e) {}
          // Forward to the details page where we collect first/last name, country, and persist.
          var qs = 'email=' + encodeURIComponent(email);
          if (name) qs += '&name=' + encodeURIComponent(name);
          window.location.href = 'subscribe-details.html?' + qs;
        });
      })();
    </script>
